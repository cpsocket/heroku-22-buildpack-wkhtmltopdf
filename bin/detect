#!/usr/bin/env bash
# bin/detect BUILD_DIR

BUILD_DIR=$1


if [ "$STACK" = "heroku-20" ] || [ "$STACK" = "heroku-22" ] || [ "$STACK" = "heroku-24" ] || [ "$STACK" = "heroku-26" ]; then
	echo "wkhtmltopdf"
else
	echo "ERROR: wkhtmltopdf was tested only to work on heroku-20, heroku-22, heroku-24, and heroku-26 stacks only."
	exit 1
fi
